{
  "name": "simsimplay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "next build",
    "pages:dev": "npm run pages:build && wrangler pages dev out",
    "pages:deploy": "npm run pages:build && wrangler pages deploy out",
    "d1:migrate:local": "wrangler d1 migrations apply simsimplay-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply simsimplay-db --remote",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.98.0"
  }
}
